# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Admin Bootstrap — comma-separated emails that auto-become ADMIN on login
# Add your manager's email here so they get admin access immediately
# ADMIN_EMAILS=pete@tabb.cc,freewhynane62@gmail.com,jeevesh039@gmail.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Also accepted (legacy alias):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Hardhat Local Blockchain
HARDHAT_RPC_URL=http://127.0.0.1:8545
HARDHAT_MNEMONIC=test test test test test test test test test test test junk
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Express Backend (runs on separate port from Next.js)
EXPRESS_PORT=4000
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# JWT Auth (Express server)
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret
SESSION_DURATION_HOURS=168
ACCESS_TOKEN_DURATION_MINUTES=15
MAX_SESSIONS_PER_USER=10

# Email Config
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@yourdomain.com
RESEND_API_KEY=your-resend-api-key

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# Privy Auth (Web3 Login)
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Alchemy (RPC, Paymaster & Gas Policies)
NEXT_PUBLIC_ALCHEMY_API_KEY=your-alchemy-api-key
NEXT_PUBLIC_ALCHEMY_GAS_POLICY_ID=your-gas-policy-id

# Admin Live Address (for contract deploy + seed - 5% split on Neon Requiem)
ADMIN_LIVE_ADDRESS=your-base-sepolia-wallet-address

# Client-side copy so the frontend shows this address in LIVE mode
NEXT_PUBLIC_ADMIN_LIVE_ADDRESS=your-base-sepolia-wallet-address

# Web3 Network Defaults (Chain ID: 84532 for Base Sepolia, 31337 for Hardhat Localhost)
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://base-sepolia.g.alchemy.com/v2/your-alchemy-api-key
NEXT_PUBLIC_REVENUE_SPLITTER_ADDRESS=your-deployed-contract-address

# Base Sepolia / Mainnet RPCs
NEXT_PUBLIC_BASE_MAINNET_RPC=https://base-mainnet.g.alchemy.com/v2/your-alchemy-api-key
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/your-alchemy-api-key

# ERC-4337 Account Abstraction
NEXT_PUBLIC_BUNDLER_URL=https://base-sepolia.g.alchemy.com/v2/your-alchemy-api-key
NEXT_PUBLIC_PAYMASTER_URL=https://base-sepolia.g.alchemy.com/v2/your-alchemy-api-key
