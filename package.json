{
  "name": "creative-rights-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run chain\" \"npm run client\"",
    "client": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "chain": "node --stack-size=10000 node_modules/.bin/hardhat node",
    "compile": "node --stack-size=10000 node_modules/.bin/hardhat compile",
    "deploy:local": "node --stack-size=10000 node_modules/.bin/hardhat run scripts/deploy.js --network localhost",
    "seed": "node scripts/seed.js",
    "demo:full": "npm run compile && npm run deploy:local && npm run seed",
    "test:api": "node scripts/api-smoke-test.js"
  },
  "dependencies": {
