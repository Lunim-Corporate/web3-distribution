# Creative Rights Tracker - Environment Configuration Template
# Copy this file to .env.local and fill in your actual values

# ==========================================
# SUPABASE - Database & Authentication
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...

# ==========================================
# WEB3 & SMART CONTRACTS
# ==========================================
# RPC URL - Choose one:
# - Local Hardhat: http://127.0.0.1:8545
# - Sepolia Testnet: https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# - Mainnet: https://mainnet.infura.io/v3/YOUR_INFURA_KEY
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545

# Deployed RevenueSplitter contract address
NEXT_PUBLIC_REVENUE_SPLITTER_ADDRESS=0x5FbDB2315678afccb333f8a9c4882979f080a6e4

# Network Chain ID:
# - 31337 = Local Hardhat
# - 1 = Ethereum Mainnet
# - 11155111 = Sepolia Testnet
NEXT_PUBLIC_CHAIN_ID=31337

# ==========================================
# OPTIONAL - ALCHEMY API (For Mainnet Access)
# ==========================================
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key_here

# ==========================================
# How to get these values:
# ==========================================
# SUPABASE_URL & ANON_KEY:
#   1. Create a Supabase project at https://supabase.com
#   2. Go to Project Settings > API
#   3. Copy URL and anon key
#
# SUPABASE_SERVICE_ROLE_KEY:
#   1. In Supabase, go to Project Settings > API
#   2. Copy the service_role secret key (keep this secret!)
#
# RPC_URL:
#   - For local development: Start Hardhat node (npx hardhat node)
#   - For testnet: Get Infura/Alchemy key and construct URL
#
# REVENUE_SPLITTER_ADDRESS:
#   1. Deploy contract: npx hardhat run scripts/deploy.js --network localhost
#   2. Copy the contract address from deployment output
